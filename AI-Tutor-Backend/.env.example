# =============================================================================
# AI-Tutor Backend — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Server ------------------------------------------------------------------

AI_TUTOR_API_HOST=0.0.0.0
AI_TUTOR_API_PORT=8099
AI_TUTOR_STORAGE_ROOT=./data
# Optional: move lesson persistence to SQLite instead of JSON files.
# AI_TUTOR_LESSON_DB_PATH=./data/runtime/lessons.db
# Optional: move live tutor runtime sessions to SQLite while keeping
# lessons/jobs/assets on the existing file store.
# AI_TUTOR_RUNTIME_DB_PATH=./data/runtime/runtime-sessions.db
# Optional: move lesson job persistence to SQLite instead of JSON files.
# AI_TUTOR_JOB_DB_PATH=./data/runtime/lesson-jobs.db
# Optional: move async lesson queue entries to SQLite instead of JSON files.
# AI_TUTOR_QUEUE_DB_PATH=./data/runtime/lesson-queue.db
AI_TUTOR_BASE_URL=http://localhost:8099

# Optional: choose how generated media/audio assets are persisted.
# Default is local filesystem for dev.
# Set to `r2` for Cloudflare R2-backed object storage.
# AI_TUTOR_ASSET_STORE=r2
# AI_TUTOR_R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# AI_TUTOR_R2_BUCKET=ai-tutor-assets
# AI_TUTOR_R2_ACCESS_KEY_ID=your-r2-access-key
# AI_TUTOR_R2_SECRET_ACCESS_KEY=your-r2-secret
# AI_TUTOR_R2_PUBLIC_BASE_URL=https://cdn.example.com
# Optional prefix within the bucket, e.g. `schools24/dev`
# AI_TUTOR_R2_KEY_PREFIX=

# --- Authentication (optional) -----------------------------------------------
# Leave empty for open dev access. Set a secret for production.

AI_TUTOR_API_SECRET=

# --- CORS (optional) ---------------------------------------------------------

AI_TUTOR_ALLOWED_ORIGINS=http://localhost:3000

# --- Logging -----------------------------------------------------------------

AI_TUTOR_LOG_FORMAT=pretty
RUST_LOG=info

# =============================================================================
# LLM Providers — configure one primary provider or a failover chain
# =============================================================================

# ┌─────────────────────────────────────────────────────────────────────────┐
# │  OPTION A: OpenAI  (recommended — full features)                      │
# │  Supports: LLM ✅  TTS ✅  ASR ✅  Images ✅                          │
# │  Get key: platform.openai.com/api-keys                                │
# │  Auto-default model: openai:gpt-4o-mini                               │
# └─────────────────────────────────────────────────────────────────────────┘
OPENAI_API_KEY=sk-proj-your-key-here

# Optional fallback providers for resilient routing / circuit breaking.
# When these are set, the LLM factory can build a real failover chain in this order:
# 1. AI_TUTOR_MODEL
# 2. AI_TUTOR_LLM_PROVIDER_PRIORITY (if set)
# 3. remaining configured providers in built-in priority order
#
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# GOOGLE_API_KEY=AIzaSy-your-key-here

# Optional: choose the failover order across configured providers
# AI_TUTOR_LLM_PROVIDER_PRIORITY=openai,anthropic,google
# Optional: tune the provider circuit breaker
# AI_TUTOR_LLM_CIRCUIT_BREAKER_THRESHOLD=2
# AI_TUTOR_LLM_CIRCUIT_BREAKER_COOLDOWN_MS=30000

# ┌─────────────────────────────────────────────────────────────────────────┐
# │  OPTION B: OpenRouter  (200+ models via one key)                      │
# │  Supports: LLM ✅  TTS ❌  ASR ❌  Images ❌                          │
# │  Get key: openrouter.ai/keys                                          │
# │  Auto-default model: openrouter:meta-llama/llama-4-maverick           │
# └─────────────────────────────────────────────────────────────────────────┘
# OPENROUTER_API_KEY=sk-or-your-key-here

# ┌─────────────────────────────────────────────────────────────────────────┐
# │  OPTION C: Groq  (ultra-fast inference, free tier)                    │
# │  Supports: LLM ✅  TTS ❌  ASR ❌  Images ❌                          │
# │  Get key: console.groq.com/keys                                      │
# │  Auto-default model: groq:llama-3.3-70b-versatile                    │
# └─────────────────────────────────────────────────────────────────────────┘
# GROQ_API_KEY=gsk_your-key-here

# =============================================================================
# Model Override (optional — auto-set based on provider if not specified)
# =============================================================================

# AI_TUTOR_MODEL=openai:gpt-4o-mini
# Optional: phase-aware generation routing for cost/performance tuning.
# Defaults when unset:
#   outlines  -> openrouter:google/gemini-2.5-flash
#   content   -> openrouter:openai/gpt-4o-mini
#   actions   -> openrouter:openai/gpt-4o-mini
#   actions fallback -> openrouter:anthropic/claude-sonnet-4-6
# AI_TUTOR_GENERATION_OUTLINES_MODEL=openrouter:google/gemini-2.5-flash
# AI_TUTOR_GENERATION_SCENE_CONTENT_MODEL=openrouter:openai/gpt-4o-mini
# AI_TUTOR_GENERATION_SCENE_ACTIONS_MODEL=openrouter:openai/gpt-4o-mini
# AI_TUTOR_GENERATION_SCENE_ACTIONS_FALLBACK_MODEL=openrouter:anthropic/claude-sonnet-4-6
# ANTHROPIC_MODELS=claude-sonnet-4-6
# GOOGLE_MODELS=gemini-2.5-flash
# AI_TUTOR_IMAGE_MODEL=openai:gpt-image-1
# AI_TUTOR_TTS_MODEL=openai:tts-1
# AI_TUTOR_ASR_MODEL=openai:whisper-1
