{
  "claude": {
    "model": "claude-sonnet-4-6",
    "mode": "graphify-first",
    "graphify": {
      "enabled": true,
      "contextDir": ".graphify-context",
      "useMetadata": true,
      "autoRefresh": true
    },
    "codeUnderstanding": {
      "primary": "graphify",
      "fallback": "file-read",
      "strategy": "metadata-primary"
    },
    "memory": {
      "enabled": true,
      "dir": ".claude/memory"
    }
  }
}

