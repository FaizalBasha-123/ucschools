# =============================================================================
# AI-Tutor Frontend — Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# Backend API URL (where the Rust backend is running)
NEXT_PUBLIC_AI_TUTOR_API_BASE_URL=http://127.0.0.1:8099

# API Token — must match AI_TUTOR_API_SECRET on the backend
# Leave empty if backend has no auth configured (dev mode)
NEXT_PUBLIC_AI_TUTOR_API_TOKEN=
